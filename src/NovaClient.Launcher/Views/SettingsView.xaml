<UserControl x:Class="NovaClient.Launcher.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:NovaClient.Launcher.Common">
    <UserControl.Resources>
        <common:StringToVisibilityConverter x:Key="StrToVis"/>
        <Style x:Key="Label" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,8,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Launcher Settings" FontSize="20" FontFamily="Segoe UI Semibold"/>
            <Button Style="{StaticResource GhostButton}" Content="← Back" HorizontalAlignment="Right"
                    Padding="14,8" Command="{Binding BackCommand}"/>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="760" HorizontalAlignment="Left">

                <!-- Memory -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Memory" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="{Binding RamText}" Style="{StaticResource Label}"/>
                        <Slider Style="{StaticResource NovaSlider}" Minimum="{Binding RamMin}" Maximum="{Binding RamMax}"
                                Value="{Binding RamMb}" TickFrequency="512" IsSnapToTickEnabled="True"/>
                        <TextBlock Text="The launcher never allows more RAM than your system can safely provide."
                                   FontSize="11" Foreground="{DynamicResource TextDimBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Game window -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Game Window" Style="{StaticResource SectionTitle}"/>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Width="140">
                                <TextBlock Text="Width" Style="{StaticResource Label}"/>
                                <TextBox Style="{StaticResource NovaTextBox}" Text="{Binding WindowWidth}"/>
                            </StackPanel>
                            <StackPanel Width="140" Margin="14,0,0,0">
                                <TextBlock Text="Height" Style="{StaticResource Label}"/>
                                <TextBox Style="{StaticResource NovaTextBox}" Text="{Binding WindowHeight}"/>
                            </StackPanel>
                            <CheckBox Style="{StaticResource NovaCheckBox}" Content="Fullscreen"
                                      IsChecked="{Binding Fullscreen}" Margin="20,22,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Java -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Java" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="{Binding JavaInfo}" Style="{StaticResource Label}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Style="{StaticResource NovaTextBox}" Text="{Binding JavaPath, UpdateSourceTrigger=LostFocus}"
                                     FontSize="12" ToolTip="Leave empty for automatic detection"/>
                            <Button Grid.Column="1" Style="{StaticResource GhostButton}" Content="Browse…"
                                    Margin="8,0,0,0" Command="{Binding BrowseJavaCommand}"/>
                            <Button Grid.Column="2" Style="{StaticResource GhostButton}" Content="Auto-detect"
                                    Margin="8,0,0,0" Command="{Binding AutoDetectJavaCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Directories & arguments -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Game Directory &amp; JVM Arguments" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Data folder (default: %AppData%\NovaClient)" Style="{StaticResource Label}"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Style="{StaticResource NovaTextBox}" Text="{Binding GameDirectory, UpdateSourceTrigger=LostFocus}" FontSize="12"/>
                            <Button Grid.Column="1" Style="{StaticResource GhostButton}" Content="Browse…"
                                    Margin="8,0,0,0" Command="{Binding BrowseGameDirCommand}"/>
                        </Grid>
                        <TextBlock Text="Extra JVM arguments" Style="{StaticResource Label}"/>
                        <TextBox Style="{StaticResource NovaTextBox}" Text="{Binding ExtraJvmArgs, UpdateSourceTrigger=LostFocus}"
                                 FontSize="12" FontFamily="Consolas"/>
                    </StackPanel>
                </Border>

                <!-- Behavior -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="After Launching" Style="{StaticResource SectionTitle}"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="Keep launcher open" IsChecked="{Binding KeepOpen}" Foreground="{DynamicResource TextDimBrush}"/>
                            <RadioButton Content="Minimize launcher" IsChecked="{Binding MinimizeAfterLaunch}" Margin="18,0,0,0" Foreground="{DynamicResource TextDimBrush}"/>
                            <RadioButton Content="Close launcher" IsChecked="{Binding CloseAfterLaunch}" Margin="18,0,0,0" Foreground="{DynamicResource TextDimBrush}"/>
                        </StackPanel>
                        <CheckBox Style="{StaticResource NovaCheckBox}" Content="Remember Microsoft email on the login screen"
                                  IsChecked="{Binding RememberEmail}" Margin="0,14,0,0"/>
                        <CheckBox Style="{StaticResource NovaCheckBox}" Content="Disable update checks (development)"
                                  IsChecked="{Binding DisableDevUpdateChecks}" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Folders -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Folders" Style="{StaticResource SectionTitle}"/>
                        <WrapPanel>
                            <Button Style="{StaticResource GhostButton}" Content="Screenshots" Margin="0,0,8,8" Command="{Binding OpenScreenshotsCommand}"/>
                            <Button Style="{StaticResource GhostButton}" Content="Resource Packs" Margin="0,0,8,8" Command="{Binding OpenResourcePacksCommand}"/>
                            <Button Style="{StaticResource GhostButton}" Content="Game Directory" Margin="0,0,8,8" Command="{Binding OpenGameDirCommand}"/>
                            <Button Style="{StaticResource GhostButton}" Content="Logs" Margin="0,0,8,8" Command="{Binding OpenLogsCommand}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Maintenance -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Maintenance" Style="{StaticResource SectionTitle}"/>
                        <WrapPanel>
                            <Button Style="{StaticResource GhostButton}" Content="Repair Installation" Margin="0,0,8,8"
                                    Command="{Binding RepairCommand}" ToolTip="Runs a full file verification from the home screen"/>
                            <Button Style="{StaticResource GhostButton}" Content="Clear Download Cache" Margin="0,0,8,8" Command="{Binding ClearCacheCommand}"/>
                            <Button Style="{StaticResource GhostButton}" Content="Check for Updates" Margin="0,0,8,8" Command="{Binding CheckUpdatesCommand}"/>
                            <Button Style="{StaticResource DangerButton}" Content="Reset Launcher Settings" Margin="0,0,8,8" Command="{Binding ResetLauncherSettingsCommand}"/>
                            <Button Style="{StaticResource DangerButton}" Content="Reset Client Settings" Margin="0,0,8,8" Command="{Binding ResetClientSettingsCommand}"/>
                        </WrapPanel>
                        <TextBlock Text="{Binding UpdateStatus}" FontSize="12" Foreground="{DynamicResource TextDimBrush}"
                                   Visibility="{Binding UpdateStatus, Converter={StaticResource StrToVis}}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
