<UserControl x:Class="NovaClient.Launcher.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:NovaClient.Launcher.Common">
    <UserControl.Resources>
        <common:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <common:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>
        <common:StringToVisibilityConverter x:Key="StrToVis"/>
        <common:InverseBoolConverter x:Key="InvBool"/>
    </UserControl.Resources>

    <Grid Style="{StaticResource PageTransition}">
        <Border Style="{StaticResource Card}" Width="420" VerticalAlignment="Center" HorizontalAlignment="Center"
                Effect="{StaticResource PanelShadow}" Padding="36">
            <StackPanel>
                <!-- Logo + name -->
                <Image Source="/Assets/logo.png" Width="58" Height="58" HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="{Binding ClientName}" FontSize="26" FontFamily="Segoe UI Semibold"
                           HorizontalAlignment="Center" Margin="0,14,0,2"/>
                <TextBlock Text="{Binding VersionText}" FontSize="11" Foreground="{DynamicResource TextDimBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,26"/>

                <!-- Email entry -->
                <TextBlock Text="Microsoft Email" FontSize="12" Foreground="{DynamicResource TextDimBrush}" Margin="2,0,0,6"/>
                <Grid>
                    <TextBox Style="{StaticResource NovaTextBox}"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                             x:Name="EmailBox" KeyDown="EmailBox_KeyDown"/>
                    <TextBlock Text="name@example.com" Margin="13,0,0,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextDimBrush}" IsHitTestVisible="False" Opacity="0.55">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=EmailBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <CheckBox Style="{StaticResource NovaCheckBox}" Content="Remember Email"
                          IsChecked="{Binding RememberEmail}" Margin="2,12,0,0"/>

                <!-- Continue button / spinner -->
                <Button Style="{StaticResource NovaButton}" Margin="0,20,0,0" Height="44"
                        Command="{Binding ContinueCommand}"
                        Visibility="{Binding IsBusy, Converter={StaticResource InvBoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconArrowRight}" Stroke="White" StrokeThickness="2"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Stretch="Uniform" Width="15" Height="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Continue with Microsoft" Foreground="White" FontFamily="Segoe UI Semibold"/>
                    </StackPanel>
                </Button>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0" Height="44"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <Ellipse Style="{StaticResource Spinner}"/>
                </StackPanel>

                <!-- Status + error -->
                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextDimBrush}" FontSize="12"
                           TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,12,0,0"
                           Visibility="{Binding StatusText, Converter={StaticResource StrToVis}}"/>
                <TextBlock Text="{Binding ErrorText}" Foreground="{DynamicResource DangerBrush}" FontSize="12"
                           TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,12,0,0" TextAlignment="Center"
                           Visibility="{Binding ErrorText, Converter={StaticResource StrToVis}}"/>

                <!-- Saved accounts (multi-account quick switch) -->
                <StackPanel Visibility="{Binding HasSavedAccounts, Converter={StaticResource BoolToVis}}">
                    <Separator Margin="0,20,0,10" Background="{DynamicResource BorderBrush}"/>
                    <TextBlock Text="Saved accounts" FontSize="11" Foreground="{DynamicResource TextDimBrush}" Margin="2,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding SavedAccounts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Style="{StaticResource GhostButton}" Command="{Binding UseCommand}"
                                            HorizontalContentAlignment="Left" Padding="12,8">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center"
                                                  Fill="{DynamicResource AccentBrush}"
                                                  Data="M 50,0 L 62,38 100,50 62,62 50,100 38,62 0,50 38,38 Z"/>
                                            <TextBlock Text="{Binding Name}" Margin="10,0,0,0" FontFamily="Segoe UI Semibold"/>
                                            <TextBlock Text="{Binding MaskedEmail}" Margin="10,1,0,0" FontSize="11"
                                                       Foreground="{DynamicResource TextDimBrush}"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1" Style="{StaticResource CaptionButton}"
                                            Width="30" Height="30" Margin="6,0,0,0" ToolTip="Forget this account"
                                            Command="{Binding RemoveCommand}">
                                        <Path Data="{StaticResource IconClose}" StrokeThickness="1.6" Stretch="Uniform"
                                              Width="9" Height="9"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <Separator Margin="0,22,0,14" Background="{DynamicResource BorderBrush}"/>
                <TextBlock Text="{Binding OwnershipNote}" FontSize="11" Foreground="{DynamicResource TextDimBrush}"
                           TextWrapping="Wrap" TextAlignment="Center"/>
                <TextBlock Text="{Binding PrivacyNote}" FontSize="11" Foreground="{DynamicResource TextDimBrush}"
                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0" Opacity="0.8"/>

                <Button Style="{StaticResource GhostButton}" Content="Settings" Margin="0,18,0,0" Padding="12,7"
                        HorizontalAlignment="Center" FontSize="12" Command="{Binding SettingsCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
