<UserControl x:Class="NovaClient.Launcher.Views.ComingSoonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Style="{StaticResource PageTransition}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="380">
            <Path Data="M 50,0 L 62,38 100,50 62,62 50,100 38,62 0,50 38,38 Z"
                  Fill="{DynamicResource AccentBrush}" Opacity="0.5" Width="44" Height="44"
                  Stretch="Uniform" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding Title}" FontSize="22" FontFamily="Segoe UI Semibold"
                       HorizontalAlignment="Center" Margin="0,14,0,6"/>
            <Border Background="{DynamicResource AccentFaintBrush}" CornerRadius="6" Padding="10,3"
                    HorizontalAlignment="Center">
                <TextBlock Text="COMING SOON" FontSize="10" FontFamily="Segoe UI Semibold"
                           Foreground="{DynamicResource AccentBrush}"/>
            </Border>
            <TextBlock Text="{Binding Description}" FontSize="13" Foreground="{DynamicResource TextDimBrush}"
                       TextWrapping="Wrap" TextAlignment="Center" Margin="0,14,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
