<Window x:Class="NovaClient.Launcher.Views.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Sign in with Microsoft"
        Width="480" Height="640" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource PanelBrush}" Padding="14,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                           Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
                <TextBlock Margin="8,0,0,0" FontSize="12" Foreground="{DynamicResource TextDimBrush}"
                           Text="Official Microsoft sign-in page — Nova Client never sees your password."
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <wv2:WebView2 x:Name="WebView" Grid.Row="1"/>

        <StackPanel Grid.Row="1" x:Name="LoadingPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Ellipse Style="{StaticResource Spinner}"/>
            <TextBlock Text="Loading Microsoft sign-in…" Margin="0,12,0,0" Foreground="{DynamicResource TextDimBrush}"/>
        </StackPanel>
    </Grid>
</Window>
