<UserControl x:Class="NovaClient.Launcher.Views.VersionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:NovaClient.Launcher.Common">
    <UserControl.Resources>
        <common:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="24,8,24,24" Style="{StaticResource PageTransition}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Versions" FontSize="20" FontFamily="Segoe UI Semibold" Margin="4,0,0,14"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Tiles}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding SelectCommand}" Margin="0,0,16,16" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Card" Width="252" Height="132" CornerRadius="14"
                                            Background="{Binding Background}" ClipToBounds="True"
                                            BorderThickness="2" BorderBrush="Transparent">
                                        <Grid>
                                            <!-- Decorative star art -->
                                            <Path Data="M 50,0 L 62,38 100,50 62,62 50,100 38,62 0,50 38,38 Z"
                                                  Fill="White" Opacity="0.08" Width="150" Height="150" Stretch="Uniform"
                                                  HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-38,-38"/>
                                            <Path Data="M 50,0 L 62,38 100,50 62,62 50,100 38,62 0,50 38,38 Z"
                                                  Fill="White" Opacity="0.05" Width="46" Height="46" Stretch="Uniform"
                                                  HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,12,0,0"/>

                                            <!-- Title -->
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="26" FontFamily="Segoe UI Black"
                                                           Foreground="White" HorizontalAlignment="Center">
                                                    <TextBlock.Effect>
                                                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.6"/>
                                                    </TextBlock.Effect>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="#B0FFFFFF"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Selected check -->
                                            <Border Background="{DynamicResource AccentBrush}" CornerRadius="20" Width="24" Height="24"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,10,0"
                                                    Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}">
                                                <Path Data="{StaticResource IconCheck}" Stroke="White" StrokeThickness="2"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                      Stretch="Uniform" Width="11" Height="11"/>
                                            </Border>

                                            <!-- Addon badge (Fabric toggle / OptiFine) -->
                                            <Button Command="{Binding BadgeCommand}" HorizontalAlignment="Left"
                                                    VerticalAlignment="Bottom" Margin="10,0,0,10" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Chip" CornerRadius="6" Padding="9,4" Background="#59000000">
                                                            <TextBlock Text="{Binding BadgeText}" FontSize="10"
                                                                       FontFamily="Segoe UI Semibold" Foreground="#B0FFFFFF"
                                                                       x:Name="ChipText"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding BadgeActive}" Value="True">
                                                                <Setter TargetName="Chip" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                <Setter TargetName="ChipText" Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Chip" Property="Opacity" Value="0.85"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Card" Property="BorderBrush" Value="#50FFFFFF"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
