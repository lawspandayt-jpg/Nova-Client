<Window x:Class="NovaClient.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NovaClient.Launcher.ViewModels"
        xmlns:views="clr-namespace:NovaClient.Launcher.Views"
        xmlns:common="clr-namespace:NovaClient.Launcher.Common"
        Title="{Binding LauncherTitle}"
        Icon="Assets/logo.png"
        Width="1010" Height="660" MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BgBrush}">

    <Window.Resources>
        <common:ActivePageBrushConverter x:Key="ActivePage"/>
        <common:BoolToVisibilityConverter x:Key="BoolToVisHeader"/>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OptiFineViewModel}">
            <views:OptiFineView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VersionsViewModel}">
            <views:VersionsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ComingSoonViewModel}">
            <views:ComingSoonView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogsViewModel}">
            <views:LogsView/>
        </DataTemplate>

        <!-- Labelled sidebar navigation item -->
        <Style x:Key="NavItem" TargetType="Button">
            <Setter Property="Width" Value="66"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Panel2Brush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavLabel" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="78"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Full-window starfield behind everything -->
        <common:StarfieldCanvas Grid.RowSpan="2" Grid.ColumnSpan="2" StarCount="3000" Panel.ZIndex="-1"/>

        <!-- Header (drag + double-click maximize) -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Background="Transparent"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" Margin="14,0" VerticalAlignment="Center">
                <Image Source="Assets/logo.png" Width="22" Height="22" RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Margin="9,0,0,0" VerticalAlignment="Center" FontSize="13.5">
                    <Run Text="Nova" FontFamily="Segoe UI Black"/><Run Text=" Client" FontFamily="Segoe UI Semibold"
                         Foreground="{DynamicResource AccentBrush}"/>
                </TextBlock>
                <TextBlock Text="{Binding VersionText}" Margin="7,1,0,0" VerticalAlignment="Center"
                           FontSize="10.5" Foreground="{DynamicResource TextDimBrush}"/>
                <Border Background="{DynamicResource Panel2Brush}" CornerRadius="6" Padding="8,3"
                        Margin="14,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Minecraft" FontSize="10" Foreground="{DynamicResource TextDimBrush}"/>
                        <TextBlock Text="{Binding SelectedVersionText}" FontSize="10" Margin="5,0,0,0"
                                   FontFamily="Segoe UI Semibold" Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                <!-- Global online count -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0"
                            Visibility="{Binding PresenceEnabled, Converter={StaticResource BoolToVisHeader}}">
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding OnlineText}" FontSize="11.5" Margin="6,0,0,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextDimBrush}" FontFamily="Segoe UI Semibold"/>
                </StackPanel>

                <!-- Account chip + dropdown menu -->
                <Grid Margin="0,0,6,0" Visibility="{Binding IsSignedIn, Converter={StaticResource BoolToVisHeader}}">
                    <Button x:Name="AccountChip" Command="{Binding ToggleAccountMenuCommand}" Cursor="Hand" Height="32">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{DynamicResource Panel2Brush}" CornerRadius="8" Padding="6,3">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border CornerRadius="4" Width="20" Height="20" Background="#33000000">
                                            <Image Source="{Binding CurrentHead}" Width="18" Height="18"
                                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                        </Border>
                                        <TextBlock Text="{Binding CurrentUsername}" Margin="7,0,5,0" VerticalAlignment="Center"
                                                   FontSize="12" FontFamily="Segoe UI Semibold"
                                                   Foreground="{DynamicResource TextBrush}"/>
                                        <Path Data="{StaticResource IconChevronDown}" Stroke="{DynamicResource TextDimBrush}"
                                              StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Stretch="Uniform" Width="9" Height="6" VerticalAlignment="Center" Margin="0,1,3,0"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BorderBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Popup IsOpen="{Binding AccountMenuOpen, Mode=TwoWay}" StaysOpen="False"
                           PlacementTarget="{Binding ElementName=AccountChip}" Placement="Bottom"
                           HorizontalOffset="0" VerticalOffset="6" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="10" Padding="6" MinWidth="210"
                                Effect="{StaticResource PanelShadow}">
                            <StackPanel>
                                <!-- Switch account: saved accounts -->
                                <TextBlock Text="SWITCH ACCOUNT" FontSize="9" FontFamily="Segoe UI Semibold"
                                           Foreground="{DynamicResource TextDimBrush}" Margin="10,6,0,4"/>
                                <ItemsControl ItemsSource="{Binding SavedAccounts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding SelectCommand}" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Row" CornerRadius="6" Padding="10,6" Background="Transparent">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                                                         Fill="{DynamicResource SuccessBrush}"
                                                                         Visibility="{Binding IsActive, Converter={StaticResource BoolToVisHeader}}"/>
                                                                <TextBlock Text="{Binding Name}" FontSize="12.5" Margin="8,0,0,0"
                                                                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Row" Property="Background" Value="{DynamicResource Panel2Brush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Style="{StaticResource GhostButton}" Content="+ Add Account" FontSize="11.5"
                                        Padding="10,6" HorizontalContentAlignment="Left" Margin="0,2,0,0"
                                        Command="{Binding AddAccountCommand}"/>

                                <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="4,8"/>

                                <Button Style="{StaticResource GhostButton}" Content="Change Skin / Cape" FontSize="12"
                                        Padding="10,7" HorizontalContentAlignment="Left" Command="{Binding ChangeSkinCommand}"/>
                                <Button Style="{StaticResource GhostButton}" Content="Screenshots" FontSize="12"
                                        Padding="10,7" HorizontalContentAlignment="Left" Margin="0,3,0,0"
                                        Command="{Binding OpenScreenshotsCommand}"/>
                                <Button Style="{StaticResource GhostButton}" Content="Account Settings" FontSize="12"
                                        Padding="10,7" HorizontalContentAlignment="Left" Margin="0,3,0,0"
                                        Command="{Binding AccountSettingsCommand}"/>

                                <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="4,8"/>

                                <Button Content="Sign Out" FontSize="12" Padding="10,7" HorizontalContentAlignment="Left"
                                        Command="{Binding HeaderSignOutCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <Button Style="{StaticResource CaptionButton}" Click="Minimize_Click" ToolTip="Minimize">
                    <Path Data="{StaticResource IconMinimize}" StrokeThickness="1.6" Stretch="Uniform" Width="11" Height="11"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <Button x:Name="MaximizeButton" Style="{StaticResource CaptionButton}" Click="Maximize_Click" ToolTip="Maximize">
                    <Path x:Name="MaximizeIcon" Data="{StaticResource IconMaximize}" StrokeThickness="1.6"
                          Stretch="Uniform" Width="10" Height="10"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <Button Style="{StaticResource CaptionButton}" Click="Close_Click" ToolTip="Close">
                    <Path Data="{StaticResource IconClose}" StrokeThickness="1.6" Stretch="Uniform" Width="10" Height="10"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Sidebar -->
        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <StackPanel HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button Style="{StaticResource NavItem}" ToolTip="Home" Command="{Binding NavPlayCommand}"
                            Background="{Binding ActivePage, Converter={StaticResource ActivePage}, ConverterParameter=Home}">
                        <StackPanel>
                            <Path Data="{StaticResource IconPlay}" Stretch="Uniform" Width="14" Height="14"
                                  HorizontalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Home" Style="{StaticResource NavLabel}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavItem}" ToolTip="Versions" Command="{Binding NavVersionsCommand}"
                            Background="{Binding ActivePage, Converter={StaticResource ActivePage}, ConverterParameter=Versions}">
                        <StackPanel>
                            <Path Data="{StaticResource IconGrid}" Stretch="Uniform" Width="14" Height="14" StrokeThickness="1.6"
                                  StrokeLineJoin="Round" HorizontalAlignment="Center"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Versions" Style="{StaticResource NavLabel}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavItem}" ToolTip="Mods" Command="{Binding NavModsCommand}"
                            Background="{Binding ActivePage, Converter={StaticResource ActivePage}, ConverterParameter=Mods}">
                        <StackPanel>
                            <Path Data="{StaticResource IconCube}" Stretch="Uniform" Width="15" Height="15" StrokeThickness="1.6"
                                  StrokeLineJoin="Round" HorizontalAlignment="Center"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Mods" Style="{StaticResource NavLabel}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavItem}" ToolTip="Servers" Command="{Binding NavServersCommand}"
                            Background="{Binding ActivePage, Converter={StaticResource ActivePage}, ConverterParameter=Servers}">
                        <StackPanel>
                            <Path Data="{StaticResource IconGlobe}" Stretch="Uniform" Width="15" Height="15" StrokeThickness="1.4"
                                  HorizontalAlignment="Center"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Servers" Style="{StaticResource NavLabel}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavItem}" ToolTip="Logs" Command="{Binding NavLogsCommand}"
                            Background="{Binding ActivePage, Converter={StaticResource ActivePage}, ConverterParameter=Logs}">
                        <StackPanel>
                            <Path Data="{StaticResource IconDoc}" Stretch="Uniform" Width="13" Height="15" StrokeThickness="1.6"
                                  StrokeLineJoin="Round" HorizontalAlignment="Center"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Logs" Style="{StaticResource NavLabel}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavItem}" ToolTip="Open the Nova Client game folder"
                            Command="{Binding OpenFolderCommand}">
                        <StackPanel>
                            <Path Data="{StaticResource IconFolder}" Stretch="Uniform" Width="15" Height="13" StrokeThickness="1.6"
                                  StrokeLineJoin="Round" HorizontalAlignment="Center"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Folder" Style="{StaticResource NavLabel}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <Button Style="{StaticResource NavItem}" ToolTip="Settings" Command="{Binding NavSettingsCommand}"
                        VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,10"
                        Background="{Binding ActivePage, Converter={StaticResource ActivePage}, ConverterParameter=Settings}">
                    <StackPanel>
                        <Path Data="{StaticResource IconGear}" Stretch="Uniform" Width="14" Height="14" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" HorizontalAlignment="Center"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Text="Settings" Style="{StaticResource NavLabel}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Active screen -->
        <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding Current}"/>
    </Grid>
</Window>
