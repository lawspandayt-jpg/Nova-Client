<Window x:Class="NovaClient.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NovaClient.Launcher.ViewModels"
        xmlns:views="clr-namespace:NovaClient.Launcher.Views"
        Title="{Binding LauncherTitle}"
        Icon="Assets/logo.png"
        Width="980" Height="640" MinWidth="820" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BgBrush}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OptiFineViewModel}">
            <views:OptiFineView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Custom title bar (double-click maximizes) -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Background="Transparent"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                <Path Width="18" Height="18" Stretch="Uniform" Fill="{DynamicResource AccentBrush}"
                      Data="M 50,0 L 62,38 100,50 62,62 50,100 38,62 0,50 38,38 Z"/>
                <TextBlock Text="{Binding LauncherTitle}" Margin="10,0,0,0" VerticalAlignment="Center"
                           FontFamily="Segoe UI Semibold" FontSize="14"/>
                <TextBlock Text="{Binding VersionText}" Margin="8,1,0,0" VerticalAlignment="Center"
                           FontSize="11" Foreground="{DynamicResource TextDimBrush}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                <Button Style="{StaticResource CaptionButton}" Content="&#xE921;" Click="Minimize_Click" ToolTip="Minimize"/>
                <Button x:Name="MaximizeButton" Style="{StaticResource CaptionButton}" Content="&#xE922;"
                        Click="Maximize_Click" ToolTip="Maximize"/>
                <Button Style="{StaticResource CaptionButton}" Content="&#xE8BB;" Click="Close_Click" ToolTip="Close"/>
            </StackPanel>
        </Grid>

        <!-- Sidebar tabs -->
        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <StackPanel HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button Style="{StaticResource SidebarButton}" Content="&#xE768;" ToolTip="Play"
                            Command="{Binding NavPlayCommand}"/>
                    <Button Style="{StaticResource SidebarButton}" Content="&#xE7FC;" ToolTip="OptiFine Setup"
                            Command="{Binding NavOptiFineCommand}"/>
                    <Button Style="{StaticResource SidebarButton}" Content="&#xE8B7;" ToolTip="Game Folder"
                            Command="{Binding OpenFolderCommand}"/>
                    <Button Style="{StaticResource SidebarButton}" Content="&#xE774;" ToolTip="Website"
                            Command="{Binding OpenWebsiteCommand}"/>
                </StackPanel>
                <Button Style="{StaticResource SidebarButton}" Content="&#xE713;" ToolTip="Settings"
                        Command="{Binding NavSettingsCommand}" VerticalAlignment="Bottom"
                        HorizontalAlignment="Center" Margin="0,0,0,12"/>
            </Grid>
        </Border>

        <!-- Active screen -->
        <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding Current}"/>
    </Grid>
</Window>
